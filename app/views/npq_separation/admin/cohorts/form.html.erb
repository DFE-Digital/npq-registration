<% if @cohort.persisted? %>
  <%= govuk_back_link href: npq_separation_admin_cohort_path(@cohort) %>
<% else %>
  <%= govuk_back_link href: npq_separation_admin_cohorts_path %>
<% end %>

<h1 class="govuk-heading-l">
  <% if @cohort.new_record? %>
    New cohort
  <% else %>
    Edit cohort
  <% end %>
</h1>

<%= form_with model: [:npq_separation, :admin, @cohort] do |f| %>
  <%= f.govuk_text_field :description %>

  <%= f.govuk_number_field :start_year,
                           label: { text: "Start year" },
                           width: 4 %>

  <%= f.govuk_text_field :suffix,
                           label: { text: "Suffix" },
                           width: 2 %>

  <%= f.govuk_collection_radio_buttons :funding, Cohort.fundings.keys, :to_s, :to_s %>

  <%= f.govuk_date_field :registration_start_date,
                         legend: { text: "Registration start date" },
                         class: "govuk-!-margin-top-5" %>

  <%= f.govuk_submit @cohort.new_record? ? "Create cohort" : "Update cohort" %>
<% end %>
