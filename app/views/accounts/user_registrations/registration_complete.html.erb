<% content_for :title, "Registration complete" %>

<div class="govuk-grid-row">
  <div class="govuk-grid-column-two-thirds">
    <%= govuk_panel(title_text: "Registration complete") do %>
      Your Registration ID<br>
      <strong><%= @application.ecf_id %></strong>
    <% end %>

    <p class="govuk-body">We have sent you a confirmation email.</p>

    <h2 class="govuk-heading-m">What happens next</h2>

    <p class="govuk-body">We&rsquo;ve sent your registration to <%= @application.lead_provider.name %>, your provider.</p>

    <p class="govuk-body">They will aim to contact you within 5 working days and ask you to complete their application form.</p>

    <p class="govuk-body"><%= govuk_link_to "Review a summary of your registration", accounts_user_registration_path(@application) %>.</p>
  </div>
</div>
